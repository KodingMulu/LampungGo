generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MITRA
  ADMIN_WILAYAH
  SUPER_ADMIN
}

enum MitraStatus {
  PENDING
  APPROVED
  REJECTED
}

model Region {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  admins      UserProfile[]

  createdAt   DateTime @default(now())
  updateAt    DateTime @updatedAt
}

model UserProfile {
  id        String @id @default(uuid())
  accountId String @unique
  email     String @unique
  name      String
  role      Role   @default(USER)

  regionId    String?
  region      Region?     @relation(fields: [regionId], references: [id])
  phoneNumber String?
  avatarUrl   String?
  mitraStatus MitraStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
